rules_version = '2';

// firestore.rules — CreatorCircle
//
// Deploy with:
//   firebase deploy --only firestore:rules
//
// ── SECURITY MODEL ──────────────────────────────────────────────────────────
// Every signed-in user can read broadly (member directories, circles, queue,
// activity log) since this is a community app where members see each
// other's stats/handles. WRITES are the security boundary, and the most
// important rule in this file is the one on users/{userId}: a user can only
// ever touch a fixed allow-list of "self-service" fields on their own doc
// (selfEditableFields() below). Anything else — role, status, points,
// verified, etc. — can only be changed by an existing admin/moderator.
// Without that allow-list, a signed-in user could call updateDoc() with
// { role: "superadmin" } on their own doc from the browser console and grant
// themselves admin access — this file exists specifically to prevent that.

service cloud.firestore {
  match /databases/{database}/documents {

    // True if the requesting user's own profile doc has an admin-level role.
    // Checked via get() rather than a custom claim so role changes (e.g.
    // promoting someone from the Team tab) take effect immediately without
    // the user needing to sign in again.
    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.role in
          ['admin', 'moderator', 'superadmin'];
    }

    function isSuperAdmin(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.role == 'superadmin';
    }

    // "support" role is intentionally excluded from isAdmin() (it can't
    // moderate the queue, manage members, or touch payouts) but its whole
    // purpose is handling support tickets, so it needs the same "see every
    // ticket" visibility an admin/moderator gets — just scoped to this one
    // collection.
    function isSupportStaff(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.role in
          ['support', 'admin', 'moderator', 'superadmin'];
    }

    // Fields a member may change on their OWN profile doc. Deliberately
    // excludes: role, status, circle, points, supportCount, verified,
    // verifiedAtSupportCount, verifiedAt, approvedBy, walletBalance,
    // provider, joined, createdAt — all of those are admin/system-only.
    // points specifically is excluded even for self-service actions like
    // "confirm support" or referral bonuses, because a direct client write
    // has no way to verify the action actually happened — see the comment
    // above addPoints() in creator-support-circle.jsx for how the app
    // handles this (those actions are local-only/optimistic, not
    // persisted, until a verified server-side awarding path exists).
    function selfEditableFields() {
      return ['name', 'handle', 'username', 'bio', 'email', 'plan',
              'contentType', 'notifPrefs', 'iban', 'referrals', 'affiliates',
              'automations', 'safetySettings', 'igConnection',
              'hasAutoReplyAddon'];
    }

    function onlySelfEditableFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(selfEditableFields());
    }

    match /users/{userId} {
      // Any signed-in member can read any profile — needed for the member
      // directory, circle rosters, and leaderboard-style views.
      allow read: if request.auth != null;

      // Self-signup: SignupForm and the Google-first-login auto-provision
      // both create their own doc, keyed by their own uid.
      allow create: if request.auth != null && request.auth.uid == userId;

      // A member can update ONLY the self-service fields on their own doc
      // (profile edits, settings, etc.) — see selfEditableFields() above.
      // Admins/moderators can update anyone's doc with no field
      // restriction (approvals, point adjustments, role changes, etc.).
      allow update: if request.auth != null && (
        (request.auth.uid == userId && onlySelfEditableFieldsChanged()) ||
        isAdmin(request.auth.uid)
      );

      allow delete: if request.auth != null && isAdmin(request.auth.uid);

      match /pushSubscriptions/{subId} {
        // Only the savePushSubscription Cloud Function (running with admin
        // privileges, which bypasses these rules entirely) should write
        // here — client access is read-only for the owning user, mainly
        // useful for debugging "do I have an active subscription" in
        // DevTools.
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /notifications/{notificationId} {
        // A user reads/manages (marking read, etc.) only their own
        // notifications. Creating a notification FOR this user is allowed
        // for any signed-in user — that's what lets e.g. an admin approving
        // someone else's queue submission write a notification into THAT
        // submitter's subcollection (see notifyUser() in the app). It's
        // intentionally not restricted to admins only, since member-to-
        // member notifications (future feature) would need the same path.
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    match /circles/{circleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /plans/{planKey} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /queue/{queueId} {
      allow read: if request.auth != null;

      // Any signed-in member can submit a post.
      allow create: if request.auth != null;

      // Admins/moderators approve or reject (status flips to
      // "approved"/"rejected" — the doc stays around permanently so a
      // member's own History tab and the public approved-posts feed both
      // have something real to show; see QueueTab.approve()/reject() in
      // the app). The original submitter can also edit or withdraw their
      // own still-pending submission. Any other signed-in member can ONLY
      // touch confirmedCount/confirmedBy, and only to add their own uid
      // exactly once and bump the count by exactly 1 — see
      // isValidConfirmation() below. That's what lets HomeScreen's
      // "Confirm support" button work for an approved post that isn't
      // theirs, without opening the door to editing anything else on it.
      allow update: if request.auth != null &&
        (isAdmin(request.auth.uid) || request.auth.uid == resource.data.submitterUid || isValidConfirmation());
      allow delete: if request.auth != null &&
        (isAdmin(request.auth.uid) || request.auth.uid == resource.data.submitterUid);
    }

    function isValidConfirmation() {
      let diffKeys = request.resource.data.diff(resource.data).affectedKeys();
      return diffKeys.hasOnly(['confirmedCount', 'confirmedBy']) &&
        !(request.auth.uid in resource.data.confirmedBy) &&
        request.auth.uid in request.resource.data.confirmedBy &&
        request.resource.data.confirmedCount == resource.data.confirmedCount + 1;
    }

    match /cashoutRequests/{requestId} {
      // Admins need to see every request to process payouts; a member only
      // needs to see their own (the app already only queries/displays the
      // logged-in user's own requests, but this is the actual enforcement).
      allow read: if request.auth != null &&
        (isAdmin(request.auth.uid) || request.auth.uid == resource.data.uid);

      // A member can create their own cashout request (uid must match their
      // own — they can't file a request on someone else's behalf).
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;

      // Only an admin marks a request paid/converted.
      allow update, delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /team/{teamId} {
      // "team" is an admin-managed staff directory used to pre-assign a
      // role to an email address before that person has even signed up —
      // see the onAuthStateChanged profile-creation logic in the app for
      // how a matching email gets its role applied on first login.
      // Superadmins can read/write the whole list. A signed-in user may
      // ALSO read only the single team doc matching their own verified
      // auth token email — that's what lets a brand-new sign-in check "was
      // I pre-assigned a role?" without granting general visibility into
      // the rest of the staff directory. request.auth.token.email comes
      // from the Firebase Auth token itself (populated for both Google and
      // email/password sign-in), not from client-supplied data, so this
      // can't be spoofed to read someone else's entry.
      allow read: if request.auth != null &&
        (isSuperAdmin(request.auth.uid) || request.auth.token.email == resource.data.email);
      allow write: if request.auth != null && isSuperAdmin(request.auth.uid);
    }

    match /activityLog/{logId} {
      // Audit log of admin actions — readable and writable by any
      // admin/moderator (any staff action can generate a log entry); not
      // readable by regular members.
      allow read: if request.auth != null && isAdmin(request.auth.uid);
      allow create: if request.auth != null && isAdmin(request.auth.uid);
      allow update, delete: if false; // audit logs are append-only
    }

    match /supportTickets/{ticketId} {
      // A member sees only their own tickets; support/admin/moderator/
      // superadmin all see every ticket (see isSupportStaff() above for why
      // "support" specifically gets this despite not being a general
      // admin). Both sides can update (append a reply message, change
      // status) — there's no field-level restriction here like users/{uid}
      // has, because the worst case of a member tampering with their own
      // ticket (e.g. marking it resolved early) only affects their own
      // support experience, not anyone else's data or money.
      allow read: if request.auth != null &&
        (isSupportStaff(request.auth.uid) || request.auth.uid == resource.data.requesterUid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.requesterUid;
      allow update: if request.auth != null &&
        (isSupportStaff(request.auth.uid) || request.auth.uid == resource.data.requesterUid);
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /submissionCooldowns/{uid} {
      // Tracks each member's own per-circle "last submitted at" timestamps
      // (used to enforce the weekly submission cooldown — see
      // recordSubmission in the app). Self-only, both read and write: a
      // user resetting their own cooldown via a direct API call is a
      // low-stakes self-only exploit (actual content moderation still goes
      // through real admin approval in the queue regardless), not worth
      // the complexity of enforcing server-timestamp-only writes here.
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}

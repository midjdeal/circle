rules_version = '2';

// Firebase Storage rules for CreatorCircle. Deploy with:
//   firebase deploy --only storage
// (If you don't have a firebase.json storage section yet, add:
//   "storage": { "rules": "storage.rules" }
// alongside the existing "firestore" section.)

service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures: profile-pictures/{uid}/{fileName}
    // Anyone signed in can view (profile pictures show up across the app —
    // live feed, admin member list, etc.) but only the account owner can
    // upload their own. Capped at 5MB and images only, since this is a
    // single cropped square photo, not a media library.
    match /profile-pictures/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
